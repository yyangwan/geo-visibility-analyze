# 智见 (ZhiJian) - Required Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: JWT signing key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
AISCOPE_SECRET_KEY=change-me-to-a-random-string

# OPTIONAL: Enable debug mode (allows default secret key)
# AISCOPE_DEBUG=1

# Platform API keys (set the ones you want to use)
AISCOPE_DEEPSEEK_API_KEY=
AISCOPE_DEEPSEEK_WEB_AUTH_TOKEN=
AISCOPE_DEEPSEEK_WEB_COOKIE=
AISCOPE_DEEPSEEK_WEB_USER_AGENT=
AISCOPE_DEEPSEEK_WEB_HEADERS_JSON=
AISCOPE_DEEPSEEK_WEB_CHAT_SESSION_ID=
AISCOPE_DEEPSEEK_WEB_PARENT_MESSAGE_ID=
AISCOPE_DEEPSEEK_WEB_MODEL_TYPE=
AISCOPE_QWEN_API_KEY=
AISCOPE_DOUBAO_API_KEY=
AISCOPE_KIMI_API_KEY=
AISCOPE_WENXIN_API_KEY=
AISCOPE_HUNYUAN_API_KEY=

# OPTIONAL: Override LLM for internal tasks (defaults to DeepSeek)
# AISCOPE_LLM_API_KEY=
# AISCOPE_LLM_BASE_URL=
# AISCOPE_LLM_MODEL=

# OPTIONAL: Timezone for scheduler (default: Asia/Shanghai)
# AISCOPE_TZ=Asia/Shanghai
